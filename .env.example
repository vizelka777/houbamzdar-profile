PORT=8080
APP_BASE_URL=https://api.houbamzdar.cz
FRONT_BASE_URL=https://houbamzdar.cz
FRONT_ORIGIN=https://houbamzdar.cz
SESSION_COOKIE_NAME=hzd_session
SESSION_COOKIE_SECURE=true
SESSION_TTL_HOURS=720

# OIDC (ahoj420)
OIDC_ISSUER=https://ahoj420.eu
OIDC_CLIENT_ID=mushroom-bff
OIDC_CLIENT_SECRET=change_me
OIDC_REDIRECT_URL=https://api.houbamzdar.cz/auth/callback
OIDC_SCOPES=openid,profile,email,phone,offline_access

# Bunny Database
DB_URL=libsql://your-db-url.turso.io
DB_TOKEN=your-db-token

# Bunny Storage
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_PRIVATE_STORAGE_ZONE=your-private-zone
BUNNY_PRIVATE_STORAGE_KEY=your-private-storage-key
BUNNY_PUBLIC_STORAGE_ZONE=your-public-zone
BUNNY_PUBLIC_STORAGE_KEY=your-public-storage-key
BUNNY_PUBLIC_BASE_URL=https://foto.houbamzdar.cz

# Capture publication validation
CAPTURE_AI_VALIDATOR_URL=https://your-bunny-edge-validator.example/api/validate-capture
CAPTURE_AI_VALIDATOR_TOKEN=your-shared-validator-token

# OSM Nominatim reverse geocoding
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=houbamzdar-mvp/1.0 (ops@houbamzdar.cz)

# Admin backups
# 0 disables the scheduler. Set e.g. 6 for one backup every 6 hours.
ADMIN_BACKUP_INTERVAL_HOURS=0
